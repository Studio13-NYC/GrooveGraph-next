                                                  "fontSize": 16,
                                                  "fontWeight": "700"
                                                },
                                                {
                                                  "type": "text",
                                                  "id": "i5ctU",
                                                  "x": 0,
                                                  "y": 49.59375,
                                                  "name": " This is the “iconic Weller guitar” period: fast, ",
                                                  "fill": "#111111ff",
                                                  "textGrowth": "fixed-width",
                                                  "width": 353,
                                                  "content": " This is the “iconic Weller guitar” period: fast, clipped rhythm playing, bright Rickenbacker/Vox-associated tones, and songs built around urgency and attack. Later Weller himself said the Rickenbackers were great but limited, which helps explain why this era feels so focused and instantly identifiable. (guitarworld.com)",
                                                  "lineHeight": 1.5499999523162842,
                                                  "fontFamily": "Inter",
                                                  "fontSize": 16,
                                                  "fontWeight": "normal"
                                                }
