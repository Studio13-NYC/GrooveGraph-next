                                                  "name": "The Jam era (late 1970s–1982): sharp mod-punk atta",
                                                  "fill": "#111111ff",
                                                  "textGrowth": "fixed-width",
                                                  "width": 327,
                                                  "content": "The Jam era (late 1970s–1982): sharp mod-punk attack",
                                                  "lineHeight": 1.5499999523162842,
