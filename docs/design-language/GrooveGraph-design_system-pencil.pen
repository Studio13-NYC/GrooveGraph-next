                                        {
                                          "type": "text",
                                          "id": "x37Si",
                                          "x": 0,
                                          "y": 0,
                                          "name": "The answer is a high-level narrative summary of Pa",
                                          "fill": "#111111ff",
                                          "textGrowth": "fixed-width",
                                          "width": 357,
                                          "content": "The answer is a high-level narrative summary of Paul Weller’s guitar evolution across career phases.",
                                          "lineHeight": 1.3499999413123498,
                                          "fontFamily": "Helvetica",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
