                                        {
                                          "type": "text",
                                          "id": "nWIqB",
                                          "x": 0,
                                          "y": 0,
                                          "name": "For Paul Weller, a useful guitar-era summary is: T",
                                          "fill": "#111111ff",
                                          "textGrowth": "fixed-width",
                                          "width": 380,
                                          "content": "For Paul Weller, a useful guitar-era summary is: The Jam = sharp mod-punk/Rickenbacker attack; Style Council = guitar de-centered in favor of soul/funk/jazz textures; 1990s solo = rediscovered acoustic/rootsy electric voice around Wild Wood and Stanley Road; later solo = increasingly eclectic, genre-crossing palette with broader guitar choices and studio experimentation.",
                                          "lineHeight": 1.3499999413123498,
                                          "fontFamily": "Helvetica",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "rTiRL",
                                      "x": 18,
