                                                  "name": "The Style Council era (1983–1989): guitar de-cente",
                                                  "fill": "#111111ff",
                                                  "textGrowth": "fixed-width",
                                                  "width": 341,
                                                  "content": "The Style Council era (1983–1989): guitar de-centered by soul, jazz, funk, and pop",
                                                  "lineHeight": 1.5499999523162842,
