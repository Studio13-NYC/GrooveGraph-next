OPENAI_API_KEY=
OPENAI_RESEARCH_MODEL=gpt-5.4
OPENAI_RESEARCH_EXTRACTION_MODEL=gpt-5.4-mini

# ---------------------------------------------------------------------------
# Graph persistence (workbench "Sync to graph") — TypeDB only
# ---------------------------------------------------------------------------
# Option A — single line (password must be URL-safe or use percent-encoding):
# TYPEDB_CONNECTION_STRING=typedb://user:pass@https://host:port/?name=database
#
# Optional: second TypeDB Cloud cluster (e.g. legacy **groove-graph** vs **groovegraph-db**).
# Cluster name in the Cloud UI is not the logical `?name=` database. Each cluster has its own host.
# Copy “Connect with TypeDB Drivers” from the **groove-graph** cluster, then:
# TYPEDB_GROOVE_GRAPH_CONNECTION_STRING=typedb://user:pass@https://OTHER-HOST/?name=DATABASE
# npm run report:typedb-db-snapshot — also snapshots this DB after the primary.
#
# Option: same TYPEDB_USERNAME / TYPEDB_PASSWORD (or same creds inside TYPEDB_CONNECTION_STRING),
# only a different cluster host + optional logical DB name:
# TYPEDB_LEGACY_ADDRESS=https://v7fqs7-0.cluster.typedb.com:80
# TYPEDB_LEGACY_DATABASE=groovegraph
#
# Option B — separate vars:
TYPEDB_USERNAME=
TYPEDB_PASSWORD=
TYPEDB_ADDRESS=
TYPEDB_DATABASE=
