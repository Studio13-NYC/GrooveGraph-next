OPENAI_API_KEY=
OPENAI_RESEARCH_MODEL=gpt-5.4
OPENAI_RESEARCH_EXTRACTION_MODEL=gpt-5.4-mini

# Graph persistence: neo4j (default) | typedb
GRAPH_PERSISTENCE_BACKEND=neo4j

# Neo4j Aura (optional; required when GRAPH_PERSISTENCE_BACKEND=neo4j)
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# TypeDB Cloud / CE (optional; required when GRAPH_PERSISTENCE_BACKEND=typedb)
# TYPEDB_CONNECTION_STRING=typedb://user:pass@https://host:port/?name=database
TYPEDB_USERNAME=
TYPEDB_PASSWORD=
TYPEDB_ADDRESS=
TYPEDB_DATABASE=
